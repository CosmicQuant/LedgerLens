rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ════════════════════════════════════════════════════
    // Receipt Images: /receipts/{userId}/{batchId}/{fileName}
    // Security: Only the owning user can read/write/delete their receipts
    // ════════════════════════════════════════════════════
    match /receipts/{userId}/{batchId}/{fileName} {

      // READ: Only the owner
      allow read: if request.auth != null && request.auth.uid == userId;

      // CREATE/UPDATE: Owner only + validation
      allow create, update: if request.auth != null
                   && request.auth.uid == userId
                   // Max 5 MB per image
                   && request.resource.size < 5 * 1024 * 1024
                   // Only image MIME types
                   && request.resource.contentType.matches('image/(jpeg|png|webp)')
                   // Must have a file extension
                   && fileName.matches('.*\\.(jpg|jpeg|png|webp)');
      
      // DELETE: Only the owner
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ════════════════════════════════════════════════════
    // Exports: /exports/{batchId}/{fileName}
    // Written by Cloud Functions (Admin SDK bypasses rules)
    // Clients can read with auth
    // ════════════════════════════════════════════════════
    match /exports/{batchId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false; // Only Admin SDK (Cloud Functions) can write
    }

    // ════════════════════════════════════════════════════
    // Default: Deny everything else
    // ════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
